# ==========================================
# ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your actual values
# ==========================================

# ==========================================
# Server Configuration
# ==========================================
PORT=3000
NODE_ENV=development
CORS_ORIGIN=*

# ==========================================
# Google Calendar API Configuration
# ==========================================
GOOGLE_PROJECT_ID=your-project-id
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour_Base64_Encoded_Key_Here\n-----END PRIVATE KEY-----\n"
GOOGLE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_CALENDAR_ID=your-calendar-email@gmail.com

# ==========================================
# Appointment Settings
# ==========================================
APPOINTMENT_SLOT_DURATION=30
OFFICE_HOURS_START=10
OFFICE_HOURS_END=18

# ==========================================
# 11za Chatbot Integration
# ==========================================
ELEVENLABS_TOKEN=your-11za-api-token
ELEVENLABS_PHONE_ID=your-11za-phone-id
ELEVENLABS_ORIGIN_WEBSITE=https://engees.in

# ==========================================
# Supabase Database Configuration
# ==========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# ==========================================
# AI Integration - Choose One Provider
# ==========================================

# Option 1: Google Gemini API
AI_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key

# Option 2: OpenAI API (for GPT-3.5/GPT-4 and Whisper)
# AI_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key

# Option 3: Groq API
# AI_PROVIDER=groq
GROQ_API_KEY=your-groq-api-key-here

# ==========================================
# Audio Transcription (Whisper API)
# Requires: OPENAI_API_KEY
# ==========================================
WHISPER_MODEL=whisper-1
WHISPER_TIMEOUT=120000

# ==========================================
# Database Settings
# ==========================================
DB_SCHEMA=public
CONVERSATION_HISTORY_LIMIT=5
CONTEXT_RETENTION_DAYS=7

# ==========================================
# Logging & Monitoring
# ==========================================
LOG_LEVEL=info
DEBUG=false

# ==========================================
# Optional Features
# ==========================================
ENABLE_VOICE_MESSAGES=true
ENABLE_MULTILINGUAL=true
ENABLE_CONTEXTUAL_MEMORY=true
ENABLE_SMART_SLOT_MATCHING=true

# ==========================================
# Implementation Notes
# ==========================================
# 
# GOOGLE_PRIVATE_KEY: 
#   - Download from Google Cloud Console
#   - Format: "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
#   - Include literal \n for newlines (not actual line breaks)
#
# AI_PROVIDER Options:
#   - "gemini": Uses Google Generative AI (free tier available)
#   - "openai": Uses OpenAI (requires paid API key, includes Whisper for audio)
#
# For Hindi/Hinglish support:
#   - OpenAI Whisper works best for Indian accents
#   - Gemini AI handles Hindi/Hinglish text prompts well
#
# Voice Message Support:
#   - Requires OPENAI_API_KEY for Whisper transcription
#   - 11za will send audio URLs in webhook
#
# Database Setup:
#   - Run database-schema-ai.sql in Supabase SQL Editor
#   - Create conversation_context, user_preferences, doctors tables
#
